---
import Button from "@components/Button.astro";
import Logo from "@assets/brand-logo.svg";

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  links?: NavLink[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  links = [
    { label: "Servicios", href: "#servicios" },
    { label: "Seguridad", href: "#seguridad" },
    { label: "Nosotros", href: "/about" },
  ],
  ctaLabel = "Agendar consulta",
  ctaHref = "#contacto",
} = Astro.props;
---

<header class="navbar sticky top-0 z-50">
  <div
    class="navbar-bar border-b border-border/40 bg-background/75 backdrop-blur-xl"
  >
    <nav
      class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:gap-8 sm:px-6 lg:h-[4.25rem] lg:px-8"
      aria-label="Principal"
    >
      <a href="/" class="navbar-logo">
        <!-- <img
          src={Logo.src}
          alt="DevOptions"
          width={Logo.width}
          height={Logo.height}
          loading="lazy"
          decoding="async"
          class="h-7 w-auto lg:h-8"
        /> -->
        <span class="site-nav-wordmark">
          <span class="site-nav-wordmark-dev">Dev</span><span
            class="site-nav-wordmark-options">Options</span
          >
        </span>
      </a>

      <div class="nav-desktop-end">
        <ul class="nav-desktop-links">
          {
            links.map((link) => (
              <li>
                <a href={link.href} class="nav-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <div class="nav-cta-desktop">
          <Button href={ctaHref} class="nav-cta-button text-body-sm">
            {ctaLabel}
          </Button>
        </div>
      </div>

      <button
        type="button"
        class="nav-mobile-trigger"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="nav-mobile-menu"
      >
        <span class="nav-mobile-icon" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </button>
    </nav>
  </div>

  <div
    id="nav-mobile-menu"
    class="nav-mobile-layer"
    hidden
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
  >
    <button
      type="button"
      class="nav-mobile-backdrop bg-neutral-900/35 backdrop-blur-sm"
      aria-label="Cerrar menú"
      tabindex="-1"></button>

    <div class="nav-mobile-panel bg-background/90 backdrop-blur-md">
      <ul>
        {
          links.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
      <Button
        href={ctaHref}
        class="mt-4 w-full justify-center py-3 text-body-sm"
      >
        {ctaLabel}
      </Button>
    </div>
  </div>
</header>

<script>
  const MOBILE_NAV_QUERY = "(max-width: 767px)";

  const trigger = document.querySelector(".nav-mobile-trigger");
  const menu = document.getElementById("nav-mobile-menu");
  const backdrop = menu?.querySelector(".nav-mobile-backdrop");

  const isMobileNav = () => window.matchMedia(MOBILE_NAV_QUERY).matches;

  const closeMenu = () => {
    if (
      !(menu instanceof HTMLElement) ||
      !(trigger instanceof HTMLButtonElement)
    ) {
      return;
    }

    menu.hidden = true;
    trigger.setAttribute("aria-expanded", "false");
    trigger.setAttribute("aria-label", "Abrir menú");
    document.body.classList.remove("nav-menu-open");
  };

  const openMenu = () => {
    if (
      !isMobileNav() ||
      !(menu instanceof HTMLElement) ||
      !(trigger instanceof HTMLButtonElement)
    ) {
      return;
    }

    menu.hidden = false;
    trigger.setAttribute("aria-expanded", "true");
    trigger.setAttribute("aria-label", "Cerrar menú");
    document.body.classList.add("nav-menu-open");
  };

  if (
    trigger instanceof HTMLButtonElement &&
    menu instanceof HTMLElement &&
    backdrop instanceof HTMLButtonElement
  ) {
    closeMenu();

    trigger.addEventListener("click", () => {
      if (!isMobileNav()) {
        closeMenu();
        return;
      }

      if (menu.hidden) {
        openMenu();
      } else {
        closeMenu();
      }
    });

    backdrop.addEventListener("click", closeMenu);

    menu.querySelectorAll(".nav-mobile-panel a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.matchMedia(MOBILE_NAV_QUERY).addEventListener("change", (event) => {
      if (!event.matches) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !menu.hidden) {
        closeMenu();
        trigger.focus();
      }
    });
  }
</script>

<style>
  .navbar-bar {
    position: relative;
    z-index: 50;
  }

  .navbar-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.95;
    transition: opacity 0.15s ease;
  }

  .navbar-logo:hover {
    opacity: 1;
  }

  .site-nav-wordmark {
    display: inline-flex;
    align-items: baseline;
    font-family: var(--font-display);
    font-size: var(--text-heading-h1);
    line-height: 1;
    font-weight: 900;
    letter-spacing: -0.02em;
  }
  .site-nav-wordmark-dev {
    color: var(--color-brand-4);
    /* background-color: var(--color-brand-1); */
  }

  .site-nav-wordmark-options {
    color: var(--color-brand-1);
    /* background-color: var(--color-brand-4); */
  }

  .nav-link {
    display: block;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-text-secondary);
    border-radius: 0.375rem;
    transition: color 0.15s ease;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-brand-2);
    outline: none;
  }

  .nav-desktop-end {
    display: none;
    align-items: center;
    gap: 0.75rem;
    margin-left: auto;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .nav-desktop-end {
      display: flex;
    }
  }

  .nav-desktop-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    min-width: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-cta-desktop {
    display: none;
    flex-shrink: 0;
    align-items: center;
  }

  @media (min-width: 768px) {
    .nav-cta-desktop {
      display: flex;
    }
  }

  .nav-cta-desktop :global(a) {
    height: auto;
    min-height: 0;
    align-self: center;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    line-height: 1.4;
    white-space: nowrap;
  }

  .nav-mobile-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    margin-left: auto;
    padding: 0;
    border: none;
    border-radius: 0.5rem;
    background: transparent;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 768px) {
    .nav-mobile-trigger,
    .nav-mobile-layer {
      display: none !important;
    }
  }

  .nav-mobile-trigger:focus-visible {
    outline: 2px solid var(--color-brand-2);
    outline-offset: 2px;
  }

  .nav-mobile-icon {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 1.25rem;
    height: 1.25rem;
  }

  .nav-mobile-icon span {
    display: block;
    height: 1.5px;
    width: 100%;
    border-radius: 9999px;
    background: var(--color-text-primary);
    opacity: 0.55;
    transition:
      opacity 0.15s ease,
      transform 0.2s ease;
  }

  .nav-mobile-trigger:hover .nav-mobile-icon span {
    opacity: 0.85;
  }

  .nav-mobile-trigger[aria-expanded="true"] .nav-mobile-icon span:first-child {
    transform: translateY(3.75px) rotate(45deg);
  }

  .nav-mobile-trigger[aria-expanded="true"] .nav-mobile-icon span:last-child {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  .nav-mobile-layer {
    position: fixed;
    inset: 0;
    z-index: 40;
  }

  .nav-mobile-layer[hidden] {
    display: none !important;
  }

  .nav-mobile-backdrop {
    position: absolute;
    inset: 0;
    top: 4rem;
    padding: 0;
    border: none;
    cursor: pointer;
  }

  .nav-mobile-panel {
    position: absolute;
    top: 4rem;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
    overflow-y: auto;
    padding: 1.25rem 1.5rem 2rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-background);
  }

  .nav-mobile-panel ul {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-mobile-panel a {
    display: block;
    padding: 0.875rem 0.75rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-primary);
    border-radius: 0.5rem;
    transition:
      color 0.15s ease,
      background-color 0.15s ease;
  }

  .nav-mobile-panel a:hover,
  .nav-mobile-panel a:focus-visible {
    color: var(--color-text-primary);
    background: var(--color-surface);
    outline: none;
  }

  @media (max-width: 767px) {
    :global(body.nav-menu-open) {
      overflow: hidden;
    }
  }
</style>
