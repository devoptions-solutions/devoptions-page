---
import Logo from "@assets/brand.svg";

interface FooterLink {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  navLinks?: FooterLink[];
  legalLinks?: FooterLink[];
}

const {
  navLinks = [
    { label: "Servicios", href: "#servicios" },
    { label: "Seguridad", href: "#seguridad" },
    { label: "Nosotros", href: "#nosotros" },
    { label: "Contacto", href: "#contacto" },
  ],
  legalLinks = [
    { label: "Privacidad", href: "/privacidad" },
    { label: "Términos", href: "/terminos" },
    {
      label: "LinkedIn",
      href: "https://linkedin.com/company/devoptions-labs",
      external: true,
    },
  ],
} = Astro.props;

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-glow" aria-hidden="true"></div>

  <div class="site-footer-inner">
    <div class="site-footer-grid">
      <div class="site-footer-brand">
        <a href="/" class="site-footer-logo">
          <img
            src={Logo.src}
            alt="DevOptions"
            width={Logo.width}
            height={Logo.height}
            loading="lazy"
            decoding="async"
            class="h-8 w-auto"
          />
        </a>
        <p class="site-footer-tagline">
          Desarrollo de software e implementaciones enfocadas en la seguridad de
          datos.
        </p>
        <a
          href="mailto:contacto@devoptions.solutions"
          class="site-footer-email"
        >
          contacto@devoptions.solutions
        </a>
      </div>

      <div class="site-footer-col">
        <p class="site-footer-heading">Navegación</p>
        <ul class="site-footer-links">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="site-footer-col">
        <p class="site-footer-heading">Legal</p>
        <ul class="site-footer-links">
          {
            legalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noreferrer noopener" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="site-footer-bottom">
      <p class="site-footer-copy">
        © {year} DevOptions Solutions S.A. de C.V. Todos los derechos reservados.
      </p>
      <p class="site-footer-note">
        Hecho con enfoque en seguridad y privacidad.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    background: var(--color-neutral-900);
    color: #fff;
  }

  .site-footer-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-brand-1) 20%,
      var(--color-brand-3) 80%,
      transparent
    );
    opacity: 0.7;
  }

  .site-footer-glow::after {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    width: 24rem;
    height: 8rem;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse at center top,
      rgb(95 27 242 / 0.18) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .site-footer-inner {
    position: relative;
    margin: 0 auto;
    max-width: 72rem;
    padding: 3.5rem 1.5rem 2rem;
  }

  @media (min-width: 1024px) {
    .site-footer-inner {
      padding: 4rem 2rem 2.25rem;
    }
  }

  .site-footer-grid {
    display: grid;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .site-footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 3rem;
    }
  }

  .site-footer-logo {
    display: inline-block;
    opacity: 0.95;
    transition: opacity 0.15s ease;
  }

  .site-footer-logo:hover {
    opacity: 1;
  }

  .site-footer-tagline {
    margin-top: 1rem;
    max-width: 20rem;
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm--line-height);
    color: rgb(255 255 255 / 0.55);
  }

  .site-footer-email {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-brand-4);
    transition: color 0.15s ease;
  }

  .site-footer-email:hover {
    color: #fff;
  }

  .site-footer-heading {
    font-size: var(--text-caption);
    line-height: var(--text-caption--line-height);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: rgb(255 255 255 / 0.4);
  }

  .site-footer-links {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .site-footer-links a {
    display: inline-block;
    width: fit-content;
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: rgb(255 255 255 / 0.72);
    transition: color 0.15s ease;
  }

  .site-footer-links a:hover,
  .site-footer-links a:focus-visible {
    color: #fff;
    outline: none;
  }

  .site-footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgb(255 255 255 / 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  @media (min-width: 640px) {
    .site-footer-bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .site-footer-copy {
    font-size: var(--text-caption);
    line-height: var(--text-caption--line-height);
    color: rgb(255 255 255 / 0.38);
  }

  .site-footer-note {
    font-size: var(--text-caption);
    line-height: var(--text-caption--line-height);
    color: rgb(255 255 255 / 0.28);
  }
</style>
