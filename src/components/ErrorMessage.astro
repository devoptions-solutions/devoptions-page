---
interface Props {
  title?: string;
  message?: string;
}

const {
  title = "No pudimos enviar tu mensaje",
  message = "Ocurrió un problema en nuestro servidor. Por favor intenta de nuevo en unos minutos.",
} = Astro.props;
---

<div class="error-container" role="alert">
  <div class="error-icon-wrap">
    <span class="error-ring" aria-hidden="true"></span>

    <svg
      class="error-mark"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 52 52"
      aria-hidden="true"
    >
      <circle class="error-circle" cx="26" cy="26" r="25" fill="none"></circle>
      <path class="error-x1" fill="none" d="M17 17 L35 35"></path>
      <path class="error-x2" fill="none" d="M35 17 L17 35"></path>
    </svg>
  </div>

  <p class="error-text">{title}</p>
  <p class="error-subtext">{message}</p>

  <button class="error-retry" data-contact-action="retry" type="button">
    Intentar de nuevo
  </button>
</div>

<style>
  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.75rem 1.5rem 3rem;
    min-height: 20rem;
    text-align: center;
  }

  /* ── Icon wrapper ─────────────────────────────── */
  .error-icon-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 6rem;
    height: 6rem;
  }

  /* ── SVG error mark ───────────────────────────── */
  .error-mark {
    position: relative;
    z-index: 1;
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    display: block;
    stroke-width: 4;
    stroke: #fff;
    stroke-miterlimit: 10;
    box-shadow: inset 0 0 0 0 var(--color-error);
  }

  .error-container.is-visible .error-mark {
    animation:
      fill-error 0.4s ease-in-out 0.4s forwards,
      shake 0.5s ease-in-out 0.95s both;
  }

  .error-circle {
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    stroke-width: 4;
    stroke-miterlimit: 10;
    stroke: var(--color-error);
    fill: none;
  }

  .error-container.is-visible .error-circle {
    animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
  }

  .error-x1,
  .error-x2 {
    transform-origin: 50% 50%;
    stroke-dasharray: 26;
    stroke-dashoffset: 26;
  }

  .error-container.is-visible .error-x1 {
    animation: stroke 0.25s cubic-bezier(0.65, 0, 0.45, 1) 0.75s forwards;
  }

  .error-container.is-visible .error-x2 {
    animation: stroke 0.25s cubic-bezier(0.65, 0, 0.45, 1) 0.88s forwards;
  }

  /* ── Ring ─────────────────────────────────────── */
  .error-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid var(--color-error);
    opacity: 0;
  }

  .error-container.is-visible .error-ring {
    animation: ring-expand 0.65s ease-out 1.1s forwards;
  }

  /* ── Text ─────────────────────────────────────── */
  .error-text {
    margin-top: 1.75rem;
    font-family: var(--font-display);
    font-size: var(--text-heading-h3);
    line-height: var(--text-heading-h3--line-height);
    font-weight: 700;
    color: var(--color-text-primary);
    opacity: 0;
    transform: translateY(10px);
  }

  .error-container.is-visible .error-text {
    animation: fadeUp 0.5s ease-out 1.15s forwards;
  }

  .error-subtext {
    margin-top: 0.625rem;
    max-width: 22rem;
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm--line-height);
    color: var(--color-text-secondary);
    opacity: 0;
    transform: translateY(8px);
  }

  .error-container.is-visible .error-subtext {
    animation: fadeUp 0.5s ease-out 1.3s forwards;
  }

  /* ── Retry button ─────────────────────────────── */
  .error-retry {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-background);
    font-size: var(--text-body-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    cursor: pointer;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease,
      transform 0.1s ease;
    opacity: 0;
    transform: translateY(8px);
  }

  .error-retry::before {
    content: "↩";
    font-size: 1rem;
  }

  .error-retry:hover {
    background: var(--color-surface);
    border-color: var(--color-brand-2);
    color: var(--color-primary);
  }

  .error-retry:active {
    transform: scale(0.97) translateY(0);
  }

  .error-container.is-visible .error-retry {
    animation: fadeUp 0.5s ease-out 1.45s forwards;
  }

  /* ── Keyframes ────────────────────────────────── */
  @keyframes stroke {
    100% {
      stroke-dashoffset: 0;
    }
  }

  @keyframes fill-error {
    100% {
      box-shadow: inset 0 0 0 2.5rem var(--color-error);
    }
  }

  @keyframes shake {
    0%,
    100% {
      transform: none;
    }
    15% {
      transform: translateX(-5px) rotate(-2deg);
    }
    35% {
      transform: translateX(5px) rotate(2deg);
    }
    55% {
      transform: translateX(-3px) rotate(-1deg);
    }
    75% {
      transform: translateX(3px) rotate(1deg);
    }
  }

  @keyframes ring-expand {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    100% {
      transform: scale(1.8);
      opacity: 0;
    }
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Reduced motion ───────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .error-container.is-visible .error-mark,
    .error-container.is-visible .error-circle,
    .error-container.is-visible .error-x1,
    .error-container.is-visible .error-x2,
    .error-container.is-visible .error-ring,
    .error-container.is-visible .error-text,
    .error-container.is-visible .error-subtext,
    .error-container.is-visible .error-retry {
      animation: none !important;
      opacity: 1;
      transform: none;
    }

    .error-container.is-visible .error-mark {
      box-shadow: inset 0 0 0 2.5rem var(--color-error);
    }

    .error-container.is-visible .error-circle,
    .error-container.is-visible .error-x1,
    .error-container.is-visible .error-x2 {
      stroke-dashoffset: 0;
    }
  }
</style>
