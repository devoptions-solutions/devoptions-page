---
import Button from "@components/Button.astro";
import { Image } from "astro:assets";
import Banner from "@assets/banner.webp";

interface Cta {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  cta: Cta;
}

const { title, description, cta } = Astro.props;
---

<section class="cta-banner relative overflow-hidden">
  <Image
    src={Banner}
    alt=""
    widths={[768, 1024, 1536, 1920]}
    sizes="100vw"
    class="cta-banner-image"
    loading="lazy"
    decoding="async"
    aria-hidden="true"
  />

  <div class="cta-banner-overlay" aria-hidden="true"></div>

  <div class="cta-banner-content">
    <h2 class="cta-banner-title">{title}</h2>
    <p class="cta-banner-description">{description}</p>
    <Button
      href={cta.href}
      variant="primary"
      class="cta-banner-button border-transparent bg-accent text-white hover:bg-accent-hover"
    >
      {cta.label}
    </Button>
  </div>
</section>

<style>
  .cta-banner {
    position: relative;
    isolation: isolate;
    padding: 3.5rem 1rem;
  }

  @media (min-width: 640px) {
    .cta-banner {
      padding: 5rem 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .cta-banner {
      padding: 7rem 2rem;
    }
  }

  .cta-banner-image {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .cta-banner-overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      105deg,
      rgb(47 79 79 / 0.92) 0%,
      rgb(0 71 171 / 0.82) 45%,
      rgb(255 99 71 / 0.72) 100%
    );
  }

  .cta-banner-content {
    position: relative;
    z-index: 1;
    margin: 0 auto;
    max-width: 40rem;
    text-align: center;
  }

  .cta-banner-title {
    font-family: var(--font-display);
    font-size: var(--text-heading-h1);
    line-height: var(--text-heading-h1--line-height);
    letter-spacing: var(--text-heading-h1--letter-spacing);
    font-weight: 700;
    color: #fff;
    text-wrap: balance;
  }

  .cta-banner-description {
    margin-top: 1rem;
    font-size: var(--text-body-lg);
    line-height: var(--text-body-lg--line-height);
    color: rgb(255 255 255 / 0.82);
    text-wrap: pretty;
  }

  .cta-banner-content :global(.cta-banner-button) {
    margin-top: 1.5rem;
    width: 100%;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .cta-banner-content :global(.cta-banner-button) {
      margin-top: 2rem;
      width: auto;
    }
  }
</style>
