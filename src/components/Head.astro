---
import { getImage } from "astro:assets";
import Favicon from "@public/favicon.ico";
import Banner from "@assets/banner.webp";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "DevOptions Solutions",
  description = "DevOptions — desarrollo de software e implementaciones enfocadas en la seguridad de datos.",
} = Astro.props;

const ogImage = await getImage({ src: Banner, width: 1200, format: "webp" });
const ogImageUrl = new URL(ogImage.src, Astro.site).href;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="canonical" href={canonicalUrl} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta
  property="og:image:alt"
  content="DevOptions — desarrollo seguro de software"
/>

<Favicon />
