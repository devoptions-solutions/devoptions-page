---
type InputType = "text" | "email" | "tel" | "password" | "url" | "search";

interface Props {
  label?: string;
  name: string;
  id?: string;
  type?: InputType | "textarea";
  placeholder?: string;
  required?: boolean;
  autocomplete?: string;
  rows?: number;
  hint?: string;
  class?: string;
}

const {
  label,
  name,
  id = name,
  type = "text",
  placeholder,
  required = false,
  autocomplete,
  rows = 4,
  hint,
  class: className = "",
} = Astro.props;

const isTextarea = type === "textarea";

const fieldClasses = [
  "w-full rounded-md border border-border bg-background px-4 py-3",
  "text-body-sm text-text-primary placeholder:text-text-secondary/70",
  "transition-colors",
  "focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20",
  isTextarea && "min-h-28 resize-y",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div class="flex flex-col gap-2">
  {
    label && (
      <label for={id} class="text-label-md font-bold text-text-primary">
        {label}
      </label>
    )
  }
  {
    isTextarea ? (
      <textarea
        id={id}
        name={name}
        placeholder={placeholder}
        required={required}
        rows={rows}
        class={fieldClasses}
      />
    ) : (
      <input
        id={id}
        name={name}
        type={type}
        placeholder={placeholder}
        required={required}
        autocomplete={autocomplete}
        class={fieldClasses}
      />
    )
  }
  {hint && <p class="text-caption text-text-secondary">{hint}</p>}
</div>
