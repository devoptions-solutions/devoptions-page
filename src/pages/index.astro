---
export const prerender = true;

import { Image } from "astro:assets";
import Badge from "@components/Badge.astro";
import ContactForm from "@components/ContactForm.astro";
import CtaBanner from "@components/CtaBanner.astro";
import Footer from "@components/Footer.astro";
import Hero from "@components/Hero.astro";
import MainLayout from "@layouts/MainLayout.astro";
import Navbar from "@components/Navbar.astro";
import { getServiceHref, services } from "@data/services";

// Acento visual por servicio: cobalt, cobalt claro, tomate
const cardAccents = [
  "var(--color-secondary)",
  "var(--color-secondary)",
  "var(--color-secondary)",
];
---

<MainLayout title="DevOptions — Desarrollo seguro de software">
  <Navbar />

  <Hero
    title="Protegemos tus datos en cada implementación"
    description="DevOptions desarrolla e implementa soluciones de software con enfoque en seguridad de datos, cumplimiento normativo y arquitectura robusta."
    primaryCta={{ label: "Conocer servicios", href: "#servicios" }}
    secondaryCta={{ label: "Hablar con un experto", href: "#contacto" }}
  />

  <section id="servicios" class="bg-surface py-14 sm:py-20 lg:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div data-reveal class="mx-auto max-w-2xl text-center">
        <Badge variant="brand">Servicios</Badge>
        <h2 class="mt-3 text-heading-h1 font-bold text-text-primary sm:mt-4">
          Soluciones enfocadas en seguridad
        </h2>
        <p class="mt-3 text-body-md text-text-secondary sm:mt-4">
          Desde el diseño hasta la implementación, priorizamos la protección de
          tu información.
        </p>
      </div>

      <div
        data-reveal="stagger"
        class="mt-10 grid gap-5 sm:mt-14 sm:gap-6 md:grid-cols-2 lg:grid-cols-3"
      >
        {
          services.map((service, i) => (
            <a
              href={getServiceHref(service.id)}
              class="svc-card group"
              style={`--card-accent:${cardAccents[i]}`}
            >
              <!-- Cabecera con imagen -->
              <div class="svc-card-media">
                <Image
                  src={service.image}
                  alt=""
                  widths={[480, 640, 800]}
                  sizes="(min-width:1024px) 33vw,(min-width:640px) 50vw,100vw"
                  class="svc-card-img"
                  loading="lazy"
                  decoding="async"
                />
                <div class="svc-card-overlay" aria-hidden="true" />
                <span class="svc-card-icon-badge" aria-hidden="true">
                  <img
                    src={service.icon.src}
                    alt=""
                    width="18"
                    height="18"
                  />
                </span>
              </div>

              <!-- Contenido -->
              <div class="svc-card-body">
                <h3 class="svc-card-title">{service.title}</h3>
                <p class="svc-card-desc">{service.cardDescription}</p>
                <ul class="svc-card-chips" role="list">
                  {service.highlights.map((h) => (
                    <li class="svc-chip">{h.title}</li>
                  ))}
                </ul>
              </div>

              <!-- Pie -->
              <div class="svc-card-footer" aria-hidden="true">
                <span>Explorar servicio</span>
                <svg
                  viewBox="0 0 16 16"
                  fill="none"
                  stroke="var(--color-accent)"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m6 3 5 5-5 5" />
                </svg>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section id="seguridad" class="py-14 sm:py-20 lg:py-28">
    <div class="mx-auto max-w-6xl px-4 text-center sm:px-6 lg:px-8">
      <h2 data-reveal class="text-heading-h1 font-bold text-text-primary">
        ¿Por qué DevOptions?
      </h2>
      <dl
        data-reveal="stagger"
        class="mt-8 grid grid-cols-1 gap-8 sm:mt-12 sm:grid-cols-3 sm:gap-10"
      >
        <div>
          <dt class="text-display-lg font-bold text-primary">100%</dt>
          <dd class="mt-2 text-body-sm text-text-secondary">
            Enfoque en seguridad
          </dd>
        </div>
        <div>
          <dt class="text-display-lg font-bold text-primary">Asistencia</dt>
          <dd class="mt-2 text-body-sm text-text-secondary">
            Asesoría, mantenimiento y soporte honestos
          </dd>
        </div>
        <div>
          <dt class="text-display-lg font-bold text-primary">ISO 27001</dt>
          <dd class="mt-2 text-body-sm text-text-secondary">
            Cumplimiento normativo
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <CtaBanner
    title="¿Listo para proteger tu próximo proyecto?"
    description="Agenda una consulta gratuita y descubre cómo podemos ayudarte."
    cta={{ label: "Contactar ahora", href: "#contacto" }}
  />

  <ContactForm />

  <Footer />
</MainLayout>

<style>
  /* ── Service cards ──────────────────────────────────────────── */
  .svc-card {
    display: flex;
    flex-direction: column;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
    box-shadow: 0 2px 10px rgba(15, 34, 64, 0.06);
  }

  .svc-card:hover {
    transform: translateY(-5px);
    border-color: color-mix(in srgb, var(--card-accent) 45%, transparent);
    box-shadow:
      0 20px 52px color-mix(in srgb, var(--card-accent) 16%, transparent),
      0 2px 8px rgba(15, 34, 64, 0.08);
  }

  /* ── Imagen ──────────────────────────────────────────────────── */
  .svc-card-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .svc-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    transition:
      opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .svc-card:hover .svc-card-img {
    transform: scale(1.07);
  }

  .svc-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(15, 20, 45, 0.78) 100%
    );
  }

  /* ── Icono badge ─────────────────────────────────────────────── */
  .svc-card-icon-badge {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    background: #ff6347; /* --color-accent */
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.28);
    transition: transform 0.2s ease;
  }

  .svc-card:hover .svc-card-icon-badge {
    transform: scale(1.12) rotate(-5deg);
  }

  .svc-card-icon-badge img {
    width: 1.125rem;
    height: 1.125rem;
    filter: brightness(0) invert(1);
  }

  /* ── Cuerpo ──────────────────────────────────────────────────── */
  .svc-card-body {
    flex: 1;
    padding: 1.25rem 1.25rem 1rem;
  }

  .svc-card-title {
    font-family: var(--font-display);
    font-size: var(--text-heading-h3);
    line-height: var(--text-heading-h3--line-height);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .svc-card-desc {
    margin-top: 0.5rem;
    font-size: var(--text-body-sm);
    line-height: var(--text-body-sm--line-height);
    color: var(--color-text-secondary);
  }

  /* ── Chips ───────────────────────────────────────────────────── */
  .svc-card-chips {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
  }

  .svc-chip {
    display: inline-block;
    padding: 0.2rem 0.625rem;
    font-size: var(--text-caption);
    line-height: var(--text-caption--line-height);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 9%, transparent);
    border-radius: var(--radius-full);
    border: 1px solid color-mix(in srgb, var(--card-accent) 22%, transparent);
  }

  /* ── Pie ─────────────────────────────────────────────────────── */
  .svc-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1.25rem;
    border-top: 1px solid var(--color-border);
    font-size: var(--text-body-sm);
    font-weight: 600;
    color: var(--card-accent);
    transition: background-color 0.15s ease;
  }

  .svc-card:hover .svc-card-footer {
    background: color-mix(in srgb, var(--card-accent) 5%, transparent);
  }

  .svc-card-footer svg {
    width: 0.9rem;
    height: 0.9rem;
    transition: transform 0.2s ease;
  }

  .svc-card:hover .svc-card-footer svg {
    transform: translateX(4px);
  }
</style>
