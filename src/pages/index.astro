---
export const prerender = true;

import Badge from "@components/Badge.astro";
import Card from "@components/Card.astro";
import ContactForm from "@components/ContactForm.astro";
import CtaBanner from "@components/CtaBanner.astro";
import Footer from "@components/Footer.astro";
import Hero from "@components/Hero.astro";
import MainLayout from "@layouts/MainLayout.astro";
import Navbar from "@components/Navbar.astro";
import { getServiceHref, services } from "@data/services";
---

<MainLayout title="DevOptions — Desarrollo seguro de software">
  <Navbar />

  <Hero
    title="Protegemos tus datos en cada implementación"
    description="DevOptions desarrolla e implementa soluciones de software con enfoque en seguridad de datos, cumplimiento normativo y arquitectura robusta."
    primaryCta={{ label: "Conocer servicios", href: "#servicios" }}
    secondaryCta={{ label: "Hablar con un experto", href: "#contacto" }}
  />

  <section id="servicios" class="bg-surface py-14 sm:py-20 lg:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <Badge variant="brand">Servicios</Badge>
        <h2 class="mt-3 text-heading-h1 font-bold text-text-primary sm:mt-4">
          Soluciones enfocadas en seguridad
        </h2>
        <p class="mt-3 text-body-md text-text-secondary sm:mt-4">
          Desde el diseño hasta la implementación, priorizamos la protección de
          tu información.
        </p>
      </div>

      <div
        class="mt-10 grid gap-4 sm:mt-14 sm:gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8"
      >
        {
          services.map((service) => (
            <Card
              title={service.title}
              description={service.cardDescription}
              iconBg={service.iconBg}
              href={getServiceHref(service.id)}
            >
              <img
                slot="icon"
                src={service.icon.src}
                alt=""
                width="24"
                height="24"
                loading="lazy"
                decoding="async"
              />
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <section id="seguridad" class="py-14 sm:py-20 lg:py-28">
    <div class="mx-auto max-w-6xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-heading-h1 font-bold text-text-primary">
        ¿Por qué DevOptions?
      </h2>
      <dl class="mt-8 grid grid-cols-1 gap-8 sm:mt-12 sm:grid-cols-3 sm:gap-10">
        <div>
          <dt class="text-display-lg font-bold text-primary">100%</dt>
          <dd class="mt-2 text-body-sm text-text-secondary">
            Enfoque en seguridad
          </dd>
        </div>
        <div>
          <dt class="text-display-lg font-bold text-primary">Asistencia</dt>
          <dd class="mt-2 text-body-sm text-text-secondary">
            Asesoría, mantenimiento y soporte honestos
          </dd>
        </div>
        <div>
          <dt class="text-display-lg font-bold text-primary">ISO 27001</dt>
          <dd class="mt-2 text-body-sm text-text-secondary">
            Cumplimiento normativo
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <CtaBanner
    title="¿Listo para proteger tu próximo proyecto?"
    description="Agenda una consulta gratuita y descubre cómo podemos ayudarte."
    cta={{ label: "Contactar ahora", href: "#contacto" }}
  />

  <ContactForm />

  <Footer />
</MainLayout>
