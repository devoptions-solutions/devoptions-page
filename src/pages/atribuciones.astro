---
export const prerender = true;

import Badge from "@components/Badge.astro";
import Footer from "@components/Footer.astro";
import MainLayout from "@layouts/MainLayout.astro";
import Navbar from "@components/Navbar.astro";
import {
  imageAttributions,
  unsplashLicenseUrl,
} from "@data/image-attributions";

const navLinks = [
  { label: "Servicios", href: "/#servicios" },
  { label: "Seguridad", href: "/#seguridad" },
  { label: "Contacto", href: "/#contacto" },
];
---

<MainLayout title="Atribuciones de imágenes | DevOptions">
  <Navbar links={navLinks} ctaHref="/#contacto" />

  <main class="bg-background py-14 sm:py-20 lg:py-28">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <Badge variant="neutral">Legal</Badge>

      <h1
        class="mt-4 text-display-lg font-bold tracking-tight text-text-primary"
      >
        Atribuciones de imágenes
      </h1>

      <p class="mt-4 text-body-md leading-relaxed text-text-secondary">
        Las fotografías utilizadas en este sitio provienen de
        <a
          href="https://unsplash.com/es?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText"
          class="attributions-link ml-1"
          target="_blank"
          rel="noreferrer noopener"
        >
          Unsplash
        </a>
        y se usan bajo la
        <a
          href={unsplashLicenseUrl}
          class="attributions-link ml-1"
          target="_blank"
          rel="noreferrer noopener"
        >
          licencia de Unsplash
        </a>.
      </p>

      <ul class="mt-10 space-y-6">
        {
          imageAttributions.map((item) => (
            <li class="attributions-item rounded-lg border border-border bg-surface p-5 sm:p-6">
              <p class="text-caption font-bold uppercase tracking-wide text-text-secondary">
                {item.usage}
              </p>
              <p class="mt-3 text-body-md leading-relaxed text-text-primary">
                Foto de{" "}
                <a
                  href={item.photographer.href}
                  class="attributions-link"
                  target="_blank"
                  rel="noreferrer noopener"
                >
                  {item.photographer.name}
                </a>{" "}
                en{" "}
                <a
                  href={item.photo.href}
                  class="attributions-link"
                  target="_blank"
                  rel="noreferrer noopener"
                >
                  {item.photo.label}
                </a>
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </main>

  <Footer />
</MainLayout>

<style>
  .attributions-link {
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: rgb(0 71 171 / 0.25);
    text-underline-offset: 0.15em;
    transition:
      color 0.15s ease,
      text-decoration-color 0.15s ease;
  }

  .attributions-link:hover,
  .attributions-link:focus-visible {
    color: var(--color-brand-2);
    text-decoration-color: currentColor;
    outline: none;
  }
</style>
