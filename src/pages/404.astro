---
export const prerender = true;

import Badge from "@components/Badge.astro";
import Button from "@components/Button.astro";
import Footer from "@components/Footer.astro";
import MainLayout from "@layouts/MainLayout.astro";
import Navbar from "@components/Navbar.astro";

const navLinks = [
  { label: "Servicios", href: "/#servicios" },
  { label: "Seguridad", href: "/#seguridad" },
  { label: "Nosotros", href: "/about" },
];
---

<MainLayout title="404 — Página no encontrada | DevOptions">
  <Navbar links={navLinks} ctaHref="/#contacto" />

  <main
    class="not-found relative flex min-h-[calc(100vh-4rem)] items-center overflow-hidden bg-background px-4 py-14 sm:px-6 sm:py-20 lg:min-h-[calc(100vh-4.25rem)] lg:px-8"
  >
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="not-found-grid absolute inset-0"></div>
      <div
        class="absolute -top-24 right-0 h-80 w-80 rounded-full bg-brand-4/15 blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-0 -left-16 h-72 w-72 rounded-full bg-brand-1/10 blur-3xl"
      >
      </div>
      <div
        class="absolute top-1/2 left-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-3/8 blur-3xl"
      >
      </div>
    </div>

    <div
      class="relative mx-auto grid w-full max-w-2xl items-center gap-10 sm:gap-12 lg:grid-cols-1 lg:gap-16"
    >
      <!-- <div class="text-center lg:text-left">
        <p
          class="not-found-code text-display-xl font-bold tracking-tight sm:mt-6"
          aria-hidden="true"
        >
          404
        </p>

        <h1 class="mt-4 text-heading-h1 font-bold text-text-primary">
          Ruta no encontrada
        </h1>

        <p
          class="mt-4 max-w-md text-body-md text-text-secondary lg:mx-0 mx-auto"
        >
          El recurso solicitado no existe en nuestro servidor. Revisa la URL o
          regresa al panel principal.
        </p>

        <div
          class="mt-8 flex flex-wrap items-center justify-center gap-3 sm:mt-10 sm:gap-4 lg:justify-start"
        >
          <Button href="/" class="w-full justify-center sm:w-auto"
            >Volver al inicio</Button
          >
        </div>
      </div> -->

      <div
        class="relative mx-auto w-full max-w-md lg:max-w-none"
        aria-hidden="true"
      >
        <div
          class="absolute -inset-3 rounded-3xl bg-linear-to-br from-brand-4/20 via-brand-1/10 to-brand-3/15 blur-xl"
        >
        </div>

        <div
          class="relative overflow-hidden rounded-2xl border border-border bg-white shadow-xl shadow-brand-2/8"
        >
          <div
            class="flex items-center gap-2 border-b border-border bg-surface/80 px-4 py-3"
          >
            <span class="size-2.5 rounded-full bg-error/80"></span>
            <span class="size-2.5 rounded-full bg-warning/80"></span>
            <span class="size-2.5 rounded-full bg-success/80"></span>
            <span class="ml-2 font-mono text-caption text-text-secondary">
              terminal — devoptions
            </span>
          </div>

          <div class="space-y-4 p-5 font-mono text-body-sm">
            <div class="flex flex-wrap gap-x-2 text-text-secondary">
              <span class="text-primary">$</span>
              <span>curl -I devoptions.solutions{Astro.url.pathname}</span>
            </div>

            <div
              class="border border-border bg-surface/60 p-4 text-left leading-relaxed"
            >
              <p class="text-text-secondary">
                <span class="text-brand-3">HTTP/1.1</span>
                <span class="text-error font-bold"> 404 Not Found</span>
              </p>
              <p class="mt-2 text-text-secondary">
                <span class="text-brand-2">content-type:</span> text/html
              </p>
              <p class="text-text-secondary">
                <span class="text-brand-2">x-status:</span> route_not_mapped
              </p>
            </div>

            <div
              class="flex items-start gap-3 border border-brand-4/25 bg-brand-4/8 p-4"
            >
              <div
                class="flex size-9 shrink-0 items-center justify-center rounded-md bg-brand-3/15"
              >
                <svg
                  class="size-4 text-brand-3"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M12 16v-4"></path>
                  <path d="M12 8h.01"></path>
                </svg>
              </div>
              <div class="text-left">
                <p class="text-label-md font-bold text-text-primary">
                  Sugerencia del sistema
                </p>
                <p class="mt-0.5 text-caption text-text-secondary">
                  Redirige a <span class="text-primary">/</span>
                </p>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-2 pt-1">
              {
                ["API", "CDN", "DNS"].map((node) => (
                  <div class="border border-border bg-background px-2 py-2 text-center">
                    <p class="text-[0.65rem] uppercase tracking-wider text-text-secondary">
                      {node}
                    </p>
                    <p class="mt-0.5 text-caption font-bold text-success">OK</p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div
          class="absolute -bottom-3 -right-2 rounded-lg border border-border bg-white px-3 py-2 shadow-md lg:-right-4"
        >
          <p class="font-mono text-caption text-brand-3">status: unresolved</p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</MainLayout>

<style>
  .not-found-grid {
    background-image:
      linear-gradient(to right, rgb(13 71 161 / 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(13 71 161 / 0.06) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(
      ellipse 85% 75% at 50% 45%,
      black 15%,
      transparent 100%
    );
  }

  .not-found-code {
    background: linear-gradient(
      135deg,
      var(--color-brand-2) 0%,
      var(--color-brand-3) 50%,
      var(--color-brand-4) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
</style>
