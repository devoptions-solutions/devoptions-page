---
export const prerender = true;

import { Image } from "astro:assets";
import Badge from "@components/Badge.astro";
import Button from "@components/Button.astro";
import Footer from "@components/Footer.astro";
import MainLayout from "@layouts/MainLayout.astro";
import Navbar from "@components/Navbar.astro";
import { services, type Service } from "@data/services";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { id: service.id },
    props: { service },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;

const navLinks = [
  { label: "Servicios", href: "/#servicios" },
  { label: "Seguridad", href: "/#seguridad" },
  { label: "Nosotros", href: "/about" },
];
---

<MainLayout title={service.pageTitle}>
  <Navbar links={navLinks} ctaHref="/#contacto" />

  <main>
    <section class="bg-surface py-14 sm:py-20 lg:py-28">
      <div
        class="mx-auto grid max-w-6xl items-center gap-10 px-4 sm:gap-12 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:px-8"
      >
        <div>
          <div class="flex flex-wrap items-center gap-3">
            <a
              href="/#servicios"
              class="inline-flex items-center gap-1.5 text-body-sm text-text-secondary transition-colors hover:text-primary"
            >
              <svg
                class="size-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m15 18-6-6 6-6"></path>
              </svg>
              Volver
            </a>
            <Badge variant="brand">{service.title}</Badge>
          </div>

          <h1
            class="mt-4 text-display-lg font-bold tracking-tight text-text-primary text-balance sm:mt-5"
          >
            {service.heading}
          </h1>

          <p
            class="mt-4 text-body-md leading-relaxed text-text-secondary sm:mt-6 sm:text-body-lg"
          >
            {service.description}
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <Button href="/#contacto" class="w-full justify-center sm:w-auto">
              Solicitar consulta
            </Button>
            <Button
              variant="secondary"
              href="/#servicios"
              class="w-full justify-center sm:w-auto"
            >
              Ver otros servicios
            </Button>
          </div>
        </div>

        <div class="relative">
          <div
            class="pointer-events-none absolute -inset-4 rounded-3xl bg-linear-to-br from-brand-1/20 via-brand-2/10 to-brand-3/20 blur-2xl"
            aria-hidden="true"
          >
          </div>
          <div
            class="relative overflow-hidden rounded-2xl border border-border shadow-[0_8px_40px_rgba(15,34,64,0.12)]"
          >
            <Image
              src={service.image}
              alt={service.imageAlt}
              widths={[640, 768, 1024, 1280]}
              sizes="(min-width: 1024px) 50vw, 100vw"
              class="aspect-4/3 w-full object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-14 sm:py-20 lg:py-28">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-heading-h1 font-bold text-text-primary">
            Qué incluye este servicio
          </h2>
          <p class="mt-3 text-body-md text-text-secondary sm:mt-4">
            {service.highlightsIntro}
          </p>
        </div>

        <ul class="mt-10 grid gap-4 sm:mt-14 sm:gap-6 md:grid-cols-3 lg:gap-8">
          {
            service.highlights.map((item) => (
              <li class="rounded-lg border border-border bg-background p-5 sm:p-6">
                <h3 class="text-heading-h3 font-bold text-text-primary">
                  {item.title}
                </h3>
                <p class="mt-2 text-body-sm leading-relaxed text-text-secondary">
                  {item.description}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</MainLayout>
